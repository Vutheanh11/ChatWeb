rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Chat images — only conversation participants should upload,
    // but since we validate on Firestore side, we just require auth here.
    match /chatImages/{convId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024   // 20 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // User avatars — only the owner can write their own avatar.
    match /avatars/{uid}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024    // 5 MB max
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
