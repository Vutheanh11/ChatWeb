rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────
    // Any logged-in user can read profiles (for search / display).
    // Only the owner can write their own profile.
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Conversations ──────────────────────────────────
    // Only conversation members can read the doc.
    // Create allowed if the requester is one of the members.
    // Update allowed only for members (e.g. lastMessage, unread).
    match /conversations/{convId} {
      // resource == null handles the case where we getDoc a non-existent conversation
      allow read:   if request.auth != null
                    && (resource == null || request.auth.uid in resource.data.members);
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.members;

      // Messages sub-collection
      match /messages/{msgId} {
        allow read:   if request.auth != null
                      && request.auth.uid in
                         get(/databases/$(database)/documents/conversations/$(convId)).data.members;
        allow create: if request.auth != null
                      && request.auth.uid in
                         get(/databases/$(database)/documents/conversations/$(convId)).data.members
                      && request.resource.data.from == request.auth.uid;
        // Only the original sender can recall (update) their own message
        allow update: if request.auth != null
                      && resource.data.from == request.auth.uid;
        // Only the original sender can delete their own message
        allow delete: if request.auth != null
                      && resource.data.from == request.auth.uid;
      }
    }

    // ── Friend Requests ────────────────────────────────
    // Sender or recipient can read.
    // Only the sender can create (from == auth.uid).
    // Either party can update status (accept / decline).
    match /friendRequests/{reqId} {
      allow read:   if request.auth != null
                    && (resource.data.from == request.auth.uid
                        || resource.data.to == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.from == request.auth.uid;
      allow update: if request.auth != null
                    && (resource.data.from == request.auth.uid
                        || resource.data.to == request.auth.uid);
    }

    // ── Voice Calls (WebRTC signaling) ─────────────────
    match /calls/{callId} {
      // Any authenticated user can create a call doc
      allow create: if request.auth != null;
      // Only the caller or callee can read / update the call doc
      allow read, update: if request.auth != null
                          && (request.auth.uid == resource.data.caller
                              || request.auth.uid == resource.data.callee);
      // ICE candidate sub-collections: both parties can read & create
      match /callerCandidates/{c} {
        allow read, create: if request.auth != null;
      }
      match /calleeCandidates/{c} {
        allow read, create: if request.auth != null;
      }
    }
  }
}
