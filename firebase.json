{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules",
    "bucket": "web-message-e1dc4.firebasestorage.app"
  },
  "hosting": {
    "public": "frontend",
    "ignore": [
      "firebase.json",
      "*.rules",
      "node_modules"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs18"
  }
}
